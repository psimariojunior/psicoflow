generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PAUSED
  NO_SHOW
}

model User {
  id                     String    @id @default(cuid())
  name                   String
  email                  String    @unique
  password               String
  role                   String    @default("PSYCHOLOGIST")
  phone                  String?
  avatarUrl              String?
  crp                    String?
  specialty              String?
  bio                    String?
  pixKey                 String?
  paymentInfo            String?
  emailVerified          DateTime?
  googleRefreshToken     String?
  googleCalendarId       String?
  stripeConnectAccountId String?
  plan                   String    @default("trial")
  planExpiresAt          DateTime?
  stripeSubscriptionId   String?
  stripeCustomerId       String?
  subscriptionStatus     String    @default("active")
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  active                 Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  patients               Patient[]
  subscription           Subscription?
  appointments           Appointment[]           @relation("PsychologistAppointments")
  medicalRecords         MedicalRecord[]
  transactions           FinancialTransaction[]
  notifications          Notification[]
  therapySessions        TherapySession[]
  invoices               Invoice[]
  emotionDiaries         EmotionDiary[]
  sentMessages           Message[]               @relation("SenderMessages")
  receivedMessages       Message[]               @relation("ReceiverMessages")
  permissions            UserPermission?
  consentLogs            ConsentLog[]
  auditLogs              AuditLog[]
  therapyResources       TherapyResource[]
  availabilitySlots      AvailabilitySlot[]
  closedRooms            ClosedRoom[]
  sessionTokens          SessionToken[]
  accounts               Account[]
  nextAuthSessions       NextAuthSession[]
  questionnaires         Questionnaire[]
  questionnaireResponses QuestionnaireResponse[]
  anamneses              Anamnesis[]
  crisisProtocols        CrisisProtocol[]
  crisisAccesses         CrisisProtocolAccess[]
  therapyTasks           TherapyTask[]
  receipts               Receipt[]
  waitingList            WaitingList[]
  documentTemplates      DocumentTemplate[]
  reviews                Review[]
}

model DocumentTemplate {
  id             String   @id @default(cuid())
  psychologistId String
  name           String
  category       String   @default("geral")
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  psychologist User @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId])
}

model Review {
  id             String   @id @default(cuid())
  psychologistId String
  patientName    String
  rating         Int
  comment        String
  approved       Boolean  @default(false)
  createdAt      DateTime @default(now())

  psychologist User @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId])
  @@index([approved])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model NextAuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Patient {
  id               String    @id @default(cuid())
  name             String
  email            String?
  phone            String?
  password         String?
  lastLoginAt      DateTime?
  cpf              String?
  rg               String?
  dateOfBirth      DateTime?
  gender           String?
  maritalStatus    String?
  profession       String?
  company          String?
  address          String?
  neighborhood     String?
  city             String?
  state            String?
  zipCode          String?
  emergencyContact String?
  emergencyPhone   String?
  healthInsurance  String?
  insuranceNumber  String?
  referredBy       String?
  howFound         String?
  observations     String?
  active           Boolean   @default(true)
  photoUrl         String?
  privacyConsent   Boolean   @default(false)
  stripeCustomerId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  psychologistId String
  psychologist   User   @relation(fields: [psychologistId], references: [id])

  appointments           Appointment[]
  medicalRecords         MedicalRecord[]
  invoices               Invoice[]
  emotionDiaries         EmotionDiary[]
  consentLogs            ConsentLog[]
  therapySessions        TherapySession[]
  attachments            Attachment[]
  transactions           FinancialTransaction[]
  questionnaireResponses QuestionnaireResponse[]
  anamnesis              Anamnesis?
  crisisAccesses         CrisisProtocolAccess[]
  therapyTasks           TherapyTask[]
  receipts               Receipt[]
  waitingEntries         WaitingList[]

  @@index([psychologistId])
}

model Appointment {
  id                      String            @id @default(cuid())
  title                   String?
  startTime               DateTime
  endTime                 DateTime
  status                  AppointmentStatus @default(SCHEDULED)
  type                    String?
  modality                String?           @default("presential")
  onlineRoomUrl           String?
  notes                   String?
  cancelReason            String?
  color                   String?
  isRecurring             Boolean           @default(false)
  recurringRule           String?
  price                   Float?
  paid                    Boolean           @default(false)
  paymentMethod           String?
  googleEventId           String?
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  psychologistId String
  psychologist   User    @relation("PsychologistAppointments", fields: [psychologistId], references: [id])
  patientId      String
  patient        Patient @relation(fields: [patientId], references: [id])

  therapySession TherapySession?
  notifications  Notification[]
  receipts       Receipt[]

  @@index([psychologistId])
  @@index([patientId])
  @@index([startTime])
  @@index([psychologistId, status])
  @@index([psychologistId, startTime])
}

model TherapySession {
  id            String            @id @default(cuid())
  status        AppointmentStatus @default(SCHEDULED)
  date          DateTime          @default(now())
  startedAt     DateTime?
  endedAt       DateTime?
  duration      Int?
  pausedSeconds Int?              @default(0)

  // SOAP clinical notes
  subjective String?
  objective  String?
  assessment String?
  plan       String?

  type         String?
  notes        String?
  tags         String?
  moodBefore   Int?
  moodAfter    Int?
  isRemote     Boolean  @default(false)
  recordingUrl String?
  signature    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointmentId  String?      @unique
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])
  psychologistId String
  psychologist   User         @relation(fields: [psychologistId], references: [id])

  @@index([psychologistId])
  @@index([patientId])
}

model MedicalRecord {
  id             String   @id @default(cuid())
  type           String   @default("SESSION_NOTE")
  title          String
  content        String
  isConfidential Boolean  @default(false)
  signature      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patientId      String
  patient        Patient @relation(fields: [patientId], references: [id])
  psychologistId String
  psychologist   User    @relation(fields: [psychologistId], references: [id])

  attachments Attachment[]

  @@index([psychologistId])
  @@index([patientId])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  type      String
  url       String
  size      Int?
  createdAt DateTime @default(now())

  recordId  String?
  record    MedicalRecord? @relation(fields: [recordId], references: [id])
  patientId String?
  patient   Patient?       @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([recordId])
}

model FinancialTransaction {
  id             String    @id @default(cuid())
  description    String
  type           String
  category       String?
  amount         Float
  discount       Float?    @default(0)
  dueDate        DateTime?
  paymentDate    DateTime?
  paymentMethod  String?
  paymentStatus  String    @default("PENDING")
  recurring      Boolean   @default(false)
  recurrenceRule String?
  notes          String?
  receiptUrl     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  psychologistId String
  psychologist   User     @relation(fields: [psychologistId], references: [id])
  patientId      String?
  patient        Patient? @relation(fields: [patientId], references: [id])
  invoiceId      String?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([psychologistId])
  @@index([patientId])
  @@index([invoiceId])
}

model Invoice {
  id                      String    @id @default(cuid())
  number                  String    @unique
  series                  String    @default("1")
  status                  String    @default("PENDING")
  description             String
  amount                  Float
  taxAmount               Float?    @default(0)
  totalAmount             Float
  issueDate               DateTime  @default(now())
  dueDate                 DateTime
  paidDate                DateTime?
  paymentMethod           String?
  notes                   String?
  pdfUrl                  String?
  xmlUrl                  String?
  qrCodeUrl               String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  psychologistId String
  psychologist   User    @relation(fields: [psychologistId], references: [id])
  patientId      String
  patient        Patient @relation(fields: [patientId], references: [id])

  transactions FinancialTransaction[]

  @@index([psychologistId])
  @@index([patientId])
}

model Notification {
  id           String    @id @default(cuid())
  title        String
  message      String
  channel      String
  status       String    @default("PENDING")
  sentAt       DateTime?
  readAt       DateTime?
  externalId   String?
  errorMessage String?
  scheduledAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  psychologistId String
  psychologist   User         @relation(fields: [psychologistId], references: [id])
  recipientId    String?
  patientId      String?
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([psychologistId])
  @@index([patientId])
  @@index([status])
  @@index([appointmentId])
  @@index([status, scheduledAt])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("text")
  read      Boolean  @default(false)
  roomId    String?
  createdAt DateTime @default(now())

  senderId   String
  sender     User   @relation("SenderMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User   @relation("ReceiverMessages", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
}

model EmotionDiary {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  mood         Int
  emotions     String?
  activities   String?
  notes        String?
  sleepHours   Float?
  sleepQuality Int?
  anxietyLevel Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientId      String
  patient        Patient @relation(fields: [patientId], references: [id])
  psychologistId String
  psychologist   User    @relation(fields: [psychologistId], references: [id])

  @@index([patientId])
  @@index([psychologistId])
}

model TherapyResource {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String
  content     String?
  url         String?
  category    String?
  tags        String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  psychologistId String
  psychologist   User          @relation(fields: [psychologistId], references: [id])
  tasks          TherapyTask[]

  @@index([psychologistId])
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  psychologistId String
  psychologist   User   @relation(fields: [psychologistId], references: [id])

  @@index([psychologistId])
}

model UserPermission {
  id                   String   @id @default(cuid())
  canViewPatients      Boolean  @default(true)
  canEditPatients      Boolean  @default(true)
  canDeletePatients    Boolean  @default(false)
  canViewAgenda        Boolean  @default(true)
  canEditAgenda        Boolean  @default(true)
  canViewFinancial     Boolean  @default(false)
  canEditFinancial     Boolean  @default(false)
  canViewRecords       Boolean  @default(true)
  canEditRecords       Boolean  @default(false)
  canSendNotifications Boolean  @default(false)
  canViewReports       Boolean  @default(false)
  canManageUsers       Boolean  @default(false)
  canManageSettings    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model TherapyTask {
  id          String    @id @default(cuid())
  status      String    @default("PENDING")
  notes       String?
  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  resourceId     String
  resource       TherapyResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  patientId      String
  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologistId String
  psychologist   User            @relation(fields: [psychologistId], references: [id])

  @@index([patientId])
  @@index([psychologistId])
  @@index([resourceId])
  @@index([status])
}

model ConsentLog {
  id        String    @id @default(cuid())
  type      String
  consent   Boolean
  content   String?
  signedAt  DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  patientId      String
  patient        Patient @relation(fields: [patientId], references: [id])
  psychologistId String
  psychologist   User    @relation(fields: [psychologistId], references: [id])

  @@index([patientId])
  @@index([psychologistId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}

model SessionToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}

model ClosedRoom {
  id             String   @id @default(cuid())
  roomName       String   @unique
  closedAt       DateTime @default(now())
  psychologistId String
  psychologist   User     @relation(fields: [psychologistId], references: [id])

  @@index([psychologistId])
}

model Receipt {
  id              String    @id @default(cuid())
  number          String    @unique
  patientName     String
  patientDoc      String?
  description     String
  amount          Float
  issueDate       DateTime  @default(now())
  appointmentDate DateTime?
  paymentMethod   String?
  status          String    @default("ISSUED")
  pdfUrl          String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  psychologistId String
  psychologist   User         @relation(fields: [psychologistId], references: [id])
  patientId      String?
  patient        Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)
  appointmentId  String?
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([psychologistId])
  @@index([patientId])
  @@index([number])
}

model WaitingList {
  id            String    @id @default(cuid())
  patientName   String
  patientEmail  String?
  patientPhone  String?
  preferredDay  String?
  preferredTime String?
  notes         String?
  status        String    @default("WAITING")
  notifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  psychologistId String
  psychologist   User     @relation(fields: [psychologistId], references: [id])
  patientId      String?
  patient        Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([psychologistId])
  @@index([status])
}

model BackupLog {
  id        String   @id @default(cuid())
  type      String   @default("AUTO")
  status    String   @default("SUCCESS")
  summary   String?
  fileUrl   String?
  createdAt DateTime @default(now())
}

enum QuestionnaireType {
  PHQ9
  GAD7
  BECK
  WHOQOL
  PSS
  MINI
  CUSTOM
}

model Questionnaire {
  id          String                  @id @default(cuid())
  type        QuestionnaireType
  title       String
  description String?
  questions   QuestionnaireQuestion[]
  responses   QuestionnaireResponse[]
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  psychologistId String
  psychologist   User   @relation(fields: [psychologistId], references: [id])

  @@index([psychologistId])
  @@index([type])
}

model QuestionnaireQuestion {
  id            String  @id @default(cuid())
  questionText  String
  questionOrder Int
  options       String? @default("[]")
  scaleMin      Int?    @default(0)
  scaleMax      Int?    @default(4)
  category      String?

  questionnaireId String
  questionnaire   Questionnaire         @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  answers         QuestionnaireAnswer[]

  @@index([questionnaireId])
}

model QuestionnaireResponse {
  id          String   @id @default(cuid())
  totalScore  Int?
  severity    String?
  notes       String?
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  questionnaireId String
  questionnaire   Questionnaire         @relation(fields: [questionnaireId], references: [id])
  patientId       String
  patient         Patient               @relation(fields: [patientId], references: [id])
  psychologistId  String
  psychologist    User                  @relation(fields: [psychologistId], references: [id])
  answers         QuestionnaireAnswer[]

  @@index([patientId])
  @@index([psychologistId])
  @@index([questionnaireId])
  @@index([patientId, questionnaireId])
}

model QuestionnaireAnswer {
  id    String  @id @default(cuid())
  value Int
  notes String?

  responseId String
  response   QuestionnaireResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   QuestionnaireQuestion @relation(fields: [questionId], references: [id])

  @@index([responseId])
  @@index([questionId])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeSubscriptionId String    @unique
  stripePriceId        String?
  plan                 String    @default("pro")
  status               String    @default("active")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
}

model Anamnesis {
  id              String   @id @default(cuid())
  complaints      String?
  history         String?
  medications     String?
  allergies       String?
  familyHistory   String?
  lifestyle       String?
  expectations    String?
  previousTherapy String?
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patientId      String  @unique
  patient        Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologistId String
  psychologist   User    @relation(fields: [psychologistId], references: [id])

  @@index([psychologistId])
}

model CrisisProtocol {
  id          String   @id @default(cuid())
  title       String
  description String?
  content     String
  category    String?
  tags        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  psychologistId String
  psychologist   User                   @relation(fields: [psychologistId], references: [id])
  assignedTo     CrisisProtocolAccess[]

  @@index([psychologistId])
}

model CrisisProtocolAccess {
  id        String    @id @default(cuid())
  grantedAt DateTime  @default(now())
  expiresAt DateTime?
  isActive  Boolean   @default(true)

  protocolId     String
  protocol       CrisisProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  patientId      String
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologistId String
  psychologist   User           @relation(fields: [psychologistId], references: [id])

  @@index([patientId])
  @@index([protocolId])
  @@index([psychologistId])
}
