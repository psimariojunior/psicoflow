# === Database ===
# PostgreSQL (produção): postgresql://user:password@localhost:5432/psicoflow
# SQLite (desenvolvimento): file:./dev.db
DATABASE_URL="file:./dev.db"

# === NextAuth ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# === Encryption (para dados sensíveis dos pacientes) ===
ENCRYPTION_KEY=""

# === App ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === SMTP (para recuperação de senha e notificações) ===
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@psicoflow.com.br"

# === Logging ===
# Valores: debug, info, warn, error
LOG_LEVEL="info"

# Webhook para notificação de erros (opcional)
# ERROR_WEBHOOK_URL="https://hooks.slack.com/services/..."

# === Serviços Externos (opcional) ===
# Configurar apenas quando for utilizar o recurso

# Videochamada (LiveKit)
# LIVEKIT_API_KEY=""
# LIVEKIT_API_SECRET=""
# LIVEKIT_URL="wss://..."

# Armazenamento de arquivos (S3-compatible)
# S3_ENDPOINT=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_BUCKET=""

# WhatsApp Business API
# WHATSAPP_API_KEY=""
# WHATSAPP_PHONE_ID=""
